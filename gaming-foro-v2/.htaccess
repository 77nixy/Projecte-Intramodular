# ═══════════════════════════════════════════════════════
#  NEXUS — Configuración Apache: rendimiento y seguridad
#  NOTA: en .htaccess los comentarios (#) deben ir en su
#  PROPIA línea; Apache NO admite comentarios al final de
#  una directiva (provocan error 500).
# ═══════════════════════════════════════════════════════

# Desactiva el listado de directorios (no se ven los archivos del servidor)
Options -Indexes

# ── Compresión gzip con mod_deflate ─────────────────────
# Comprime las respuestas de texto antes de enviarlas (reduce el ancho de banda)
<IfModule mod_deflate.c>
    # Comprime páginas HTML
    AddOutputFilterByType DEFLATE text/html
    # Comprime hojas de estilo CSS
    AddOutputFilterByType DEFLATE text/css
    # Comprime JavaScript (tipo antiguo)
    AddOutputFilterByType DEFLATE text/javascript
    # Comprime JavaScript (tipo estándar)
    AddOutputFilterByType DEFLATE application/javascript
    # Comprime JavaScript (tipo legacy)
    AddOutputFilterByType DEFLATE application/x-javascript
    # Comprime las respuestas JSON de la API
    AddOutputFilterByType DEFLATE application/json
    # Comprime texto plano
    AddOutputFilterByType DEFLATE text/plain
    # Comprime XML
    AddOutputFilterByType DEFLATE text/xml
    # Comprime imágenes SVG
    AddOutputFilterByType DEFLATE image/svg+xml
    # Comprime fuentes woff2
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ── Caché del navegador con mod_expires ─────────────────
# Indica cuánto tiempo puede guardar el navegador cada tipo de archivo
<IfModule mod_expires.c>
    # Activa las reglas de expiración
    ExpiresActive On
    # CSS: 1 mes de caché
    ExpiresByType text/css                  "access plus 1 month"
    # JavaScript: 1 mes
    ExpiresByType application/javascript    "access plus 1 month"
    # Imágenes PNG: 1 mes
    ExpiresByType image/png                 "access plus 1 month"
    # Imágenes JPG: 1 mes
    ExpiresByType image/jpg                 "access plus 1 month"
    # Imágenes JPEG: 1 mes
    ExpiresByType image/jpeg                "access plus 1 month"
    # Imágenes GIF: 1 mes
    ExpiresByType image/gif                 "access plus 1 month"
    # Imágenes SVG: 1 mes
    ExpiresByType image/svg+xml             "access plus 1 month"
    # Imágenes WebP: 1 mes
    ExpiresByType image/webp                "access plus 1 month"
    # Favicon: 1 año
    ExpiresByType image/x-icon              "access plus 1 year"
    # Fuentes woff2: 1 año
    ExpiresByType font/woff2                "access plus 1 year"
    # Fuentes woff: 1 año
    ExpiresByType font/woff                 "access plus 1 year"
    # HTML: sin caché (es contenido dinámico de PHP)
    ExpiresByType text/html                 "access plus 0 seconds"
    # JSON de la API: sin caché
    ExpiresByType application/json          "access plus 0 seconds"
</IfModule>

# ── Cabeceras de Cache-Control ───────────────────────────
# Refuerza la caché con cabeceras HTTP más específicas
<IfModule mod_headers.c>
    # CSS y JS: caché pública de 30 días (con ?v=9 para forzar recarga al cambiar)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    # Imágenes y fuentes: caché de 1 año (no cambian casi nunca)
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|ico|woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # PHP y JSON: nunca cachear (datos dinámicos)
    <FilesMatch "\.(php|json)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        # Evita que el navegador adivine el tipo MIME
        Header set X-Content-Type-Options "nosniff"
    </FilesMatch>
</IfModule>

# ── Conexión persistente (KeepAlive) ────────────────────
# Mantiene la conexión TCP abierta entre peticiones (carga más rápida)
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# ── Ajustes de rendimiento de PHP ───────────────────────
<IfModule php_module>
    # Buffer de salida de 4KB (mejora el rendimiento)
    php_value output_buffering 4096
    # Desactivado: las descargas de backup necesitan Content-Length exacto
    php_flag  zlib.output_compression Off
</IfModule>

# ── Codificación de caracteres ──────────────────────────
# Fuerza UTF-8 por defecto en todas las respuestas
AddDefaultCharset UTF-8

# ── Cabeceras de seguridad HTTP ─────────────────────────
# Protegen frente a vulnerabilidades comunes del navegador
<IfModule mod_headers.c>
    # Solo permite iframes del mismo dominio (anti-clickjacking)
    Header always set X-Frame-Options "SAMEORIGIN"
    # Activa el filtro XSS (para navegadores antiguos)
    Header always set X-XSS-Protection "1; mode=block"
    # Controla qué referer se envía a otros sitios
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
